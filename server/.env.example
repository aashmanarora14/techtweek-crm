# ── PostgreSQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techtweek_crm
DB_USER=crm_user
DB_PASSWORD=your_strong_password_here

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
ALLOWED_ORIGIN=http://YOUR_VPS_IP
CRM_URL=http://YOUR_VPS_IP

# ── JWT Secret (make this long and random!) ───────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_min_32_chars

# ── AWS SES Configuration ──────────────────────────────────────
# 1. Go to AWS Console → SES → Verified Identities
# 2. Verify your domain OR individual email addresses
# 3. Create IAM user with AmazonSESFullAccess policy
# 4. Generate Access Key + Secret Key for that IAM user
# 5. If in SES sandbox mode, also verify each RECIPIENT email

AWS_REGION=ap-south-1
# Use ap-south-1 (Mumbai) for India — or us-east-1, eu-west-1 etc.

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# The FROM address — must be verified in AWS SES
EMAIL_FROM=crm@techtweekinfotech.com
# Display name shown in email clients
EMAIL_FROM_NAME=TechTweek CRM
